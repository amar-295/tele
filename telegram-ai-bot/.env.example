# Copy this file to .env and fill in values. Never commit .env.

# ── Required ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
OWNER_CHAT_ID=123456789
GROQ_API_KEY=gsk_your_groq_api_key_here
UI_API_KEY=replace_with_long_random_string
CORS_ORIGIN=http://localhost:3000

# Webhooks (optional): unset = long polling. Set both for HTTPS webhook mode (e.g. Render/Railway).
# Public URL must match what Telegram calls (path defaults to "telegram" if omitted).
# TELEGRAM_WEBHOOK_URL=https://your-service.onrender.com/telegram
# TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_string
# WEBHOOK_LISTEN=0.0.0.0
# PORT=10000
# DROP_PENDING_UPDATES=false

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Model list: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
MAX_TOKENS=8192

MEMORY_TOP_K=8
MEMORY_THRESHOLD=0.60
MAX_HISTORY_MESSAGES=100
MAX_HISTORY_TOKENS=64000
MAX_FACTS_IN_PROMPT=25

CHROMA_PATH=./data/chroma
DB_PATH=./data/bot.db
LOGS_PATH=./data/logs

# Optional: PostgreSQL for messages/facts/stats + pgvector embeddings (any host: Supabase, Neon, …).
# When set, SQLite at DB_PATH is not used. Vector recall uses table embedding_memory in the same DB
# (pgvector); CHROMA_PATH is only used if DATABASE_URL is unset (local SQLite mode).
# Enable the "vector" extension in Supabase (Database → Extensions) if startup cannot CREATE EXTENSION.
#
# Supabase: Dashboard → Project Settings → Database → copy "URI" under Connection string.
# Use "Direct connection" or "Session pooler" (this bot is long‑running + asyncpg). Avoid the
# Transaction pooler (port 6543) for this app — it conflicts with prepared statements.
# Append ssl if needed, e.g. ...postgres?sslmode=require
# DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

PROACTIVE_DIGEST_ENABLED=false
PROACTIVE_DIGEST_INTERVAL_HOURS=24
